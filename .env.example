# ========================================
# CONFIGURACIÓN DE WHATSAPP BUSINESS API
# ========================================

# Token de verificación del webhook
# Genera uno personalizado (ej: monopolio_sales_2025_test)
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# Token de acceso de WhatsApp Business API
# Obtén de: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# ID del número de teléfono de WhatsApp Business
# Obtén de: https://developers.facebook.com/apps/[tu-app-id]/whatsapp-business/wa-phone-numbers
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ID de tu aplicación de WhatsApp Business (opcional, pero recomendado)
WHATSAPP_BUSINESS_APP_ID=your_business_app_id_here

# Secret de la aplicación (para mayor seguridad)
WHATSAPP_APP_SECRET=your_app_secret_here

# ========================================
# CONFIGURACIÓN DE GOOGLE GEMINI IA
# ========================================

# Clave de API de Google Gemini
# Obtén en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Nombre del modelo Gemini a usar
GEMINI_MODEL_NAME=gemini-pro

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ========================================

# Ejemplo con Supabase (opcional, para persistencia)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ========================================
# ENTORNO Y DEBUG
# ========================================

# Cambiar a "production" cuando despliegues a producción
NODE_ENV=development

# Habilitar logs detallados (true/false)
DEBUG_MODE=true
